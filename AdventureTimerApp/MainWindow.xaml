<Window x:Class="AdventureTimerApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdventureTimerApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
	<Grid Background="#FFF5F5F5">
		<StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
			<TextBlock Text="Adventure Timer Game" FontSize="24" Margin="0,0,0,20" HorizontalAlignment="Center"/>

			<TextBlock x:Name="StaminaLabel" Text="Stamina: 10" FontSize="18" Margin="0,0,0,10" HorizontalAlignment="Center"/>
			<TextBlock x:Name="ResultLabel" Text="" FontSize="16" Margin="0,10,0,10" Foreground="DarkRed" HorizontalAlignment="Center"/>

			<Button x:Name="ExploreButton" Content="Explore" Width="120" Click="ExploreButton_Click" Margin="0,5,0,5"/>
			<Button x:Name="RestButton" Content="Rest" Width="120" Click="RestButton_Click" Margin="0,5,0,5"/>

			<TextBlock Text="Adventure Log:" Margin="0,20,0,5"/>
			<ListBox x:Name="LogList" Width="280" Height="120"/>
		</StackPanel>
	</Grid>
</Window>
